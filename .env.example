# Supabase (required for Create Inspection to save)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Gemini API — used by both the React Native app and ai/ Python scripts
EXPO_PUBLIC_GEMINI_API_KEY=your_key_here
# Legacy key for ai/ Python scripts (same key, different variable name)
GEMINI_API_KEY=your_key_here

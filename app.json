{
  "expo": {
    "name": "HackIllinois26",
    "slug": "HackIllinois26",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "CATrack needs camera access to take inspection photos of equipment.",
        "NSPhotoLibraryUsageDescription": "CATrack needs photo library access to attach existing photos to inspections.",
        "NSPhotoLibraryAddUsageDescription": "CATrack saves annotated inspection photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "CATrack needs access to your photo library to attach inspection photos.",
          "cameraPermission": "CATrack needs camera access to take inspection photos."
        }
      ]
    ]
  }
}
